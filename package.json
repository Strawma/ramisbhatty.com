{
	"name": "ramisbhatty.com",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"packageManager": "pnpm@10.24.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
