			"minimist@<0.2.1": ">=0.2.1",
			"minimist@<0.2.4": ">=0.2.4",
			"cookie@<0.7.0": ">=0.7.0"
		}
	},
	"dependencies": {
		"webaudio-tinysynth": "^1.1.3"
